[
  {
    "context": "Editor",
    "use_key_equivalents": true,
    "bindings": {
      "left": "editor::MoveLeft",
      "right": "editor::MoveRight",
      "up": "editor::MoveUp",
      "down": "editor::MoveDown",
      "backspace": "editor::Backspace",
      "delete": "editor::Delete",
      "tab": "editor::Tab",
      "shift-tab": "editor::Backtab",
      "escape": "editor::Cancel",
      "shift-left": "editor::SelectLeft",
      "shift-right": "editor::SelectRight",
      "shift-up": "editor::SelectUp",
      "shift-down": "editor::SelectDown",
      "home": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "end": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "cmd-left": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "cmd-right": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "cmd-up": "editor::MoveToBeginning",
      "cmd-down": "editor::MoveToEnd",
      "alt-right": "editor::MoveToNextWordEnd",
      "alt-left": "editor::MoveToPreviousWordStart",
      "alt-up": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "alt-down": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "pageup": "editor::PageUp",
      "pagedown": "editor::PageDown",
      "cmd-g": "go_to_line::Toggle",
      "cmd-shift-left": [
        "editor::SelectToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "shift-home": [
        "editor::SelectToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "cmd-shift-right": [
        "editor::SelectToEndOfLine",
        { "stop_at_soft_wraps": true },
      ],
      "shift-end": [
        "editor::SelectToEndOfLine",
        { "stop_at_soft_wraps": true },
      ],
      "cmd-shift-up": "editor::SelectToBeginning",
      "cmd-shift-down": "editor::SelectToEnd",
      "alt-shift-right": "editor::SelectToNextWordEnd",
      "alt-shift-left": "editor::SelectToPreviousWordStart",
      "alt-shift-up": [
        "editor::SelectToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "alt-shift-down": [
        "editor::SelectToEndOfLine",
        { "stop_at_soft_wraps": true },
      ],
      "cmd-a": "editor::SelectAll",
      "cmd-l": "editor::SelectLine",
      "cmd-c": "editor::Copy",
      "cmd-x": "editor::Cut",
      "cmd-v": "editor::Paste",
      "cmd-z": "editor::Undo",
      "cmd-shift-z": "editor::Redo",
      "cmd-d": "editor::DuplicateLineDown",
      "cmd-shift-k": "editor::DeleteLine",
      "cmd-/": "editor::ToggleComments",
      "alt-backspace": [
        "editor::DeleteToPreviousWordStart",
        { "ignore_newlines": false, "ignore_brackets": false },
      ],
      "alt-delete": [
        "editor::DeleteToNextWordEnd",
        { "ignore_newlines": false, "ignore_brackets": false },
      ],
      "cmd-backspace": "editor::DeleteToBeginningOfLine",
      "cmd-delete": "editor::DeleteToEndOfLine",
      "cmd-f": "buffer_search::Deploy",
      "cmd-alt-f": "buffer_search::DeployReplace",
      "cmd-shift-f": "project_search::ToggleFocus",
    },
  },
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "enter": "editor::Newline",
    },
  },
  {
    "context": "BufferSearchBar",
    "use_key_equivalents": true,
    "bindings": {
      "enter": "search::SelectNextMatch",
      "shift-enter": "search::SelectPreviousMatch",
      "escape": "buffer_search::Dismiss",
    },
  },
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-s": "workspace::Save",
      "cmd-shift-s": "workspace::SaveAll",
      "cmd-n": "workspace::NewFile",
      "cmd-o": "workspace::Open",
      "cmd-q": "zed::Quit",
      "cmd-w": "pane::CloseActiveItem",
      "cmd-p": "file_finder::Toggle",
      "cmd-shift-p": "command_palette::Toggle",
      "cmd-1": "workspace::ToggleLeftDock",
      "cmd-2": "workspace::ToggleBottomDock",
      "ctrl-`": "terminal_panel::ToggleFocus",
      "cmd-k cmd-s": "zed::OpenKeymap",
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
    },
  },
]
