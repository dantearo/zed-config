{
  "project_name": null,

  "theme": {
    "mode": "dark",
    "light": "Ark",
    "dark": "Ark",
  },
  "icon_theme": "Zed (Default)",

  // TODO: Later.
  "base_keymap": "JetBrains",

  "features": {
    "edit_prediction_provider": null,
  },

  "buffer_font_family": "JetBrains Mono",
  "buffer_font_fallbacks": null,
  "buffer_font_size": 14,
  "buffer_font_weight": 400,
  "buffer_line_height": "comfortable",

  "ui_font_family": "JetBrains Mono",
  "ui_font_fallbacks": null,
  "ui_font_weight": 400,
  "ui_font_size": 14,

  "hover_popover_enabled": false,

  "confirm_quit": true,

  "use_system_path_prompts": false,
  "use_system_prompts": false,

  "cursor_blink": true,
  "cursor_shape": "block",

  "selection_highlight": false,

  "rounded_selection": false,

  "show_completions_on_input": false,
  "show_completion_documentation": false,

  "inline_code_actions": false,

  "drag_and_drop_selection": {
    "enabled": false,
  },

  "go_to_definition_fallback": "none",

  "diagnostics_max_severity": "off",

  "show_wrap_guides": true,

  "wrap_guides": [80],

  "use_on_type_format": false,

  "use_autoclose": false,

  "use_auto_surround": false,

  "show_edit_predictions": false,

  "show_whitespaces": "trailing",

  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },

  "use_system_window_tabs": false,

  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_menus": false,
  },

  "scrollbar": {
    "diagnostics": "none",
  },

  "middle_click_paste": false,

  "gutter": {
    "line_numbers": false,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
    "min_line_number_digits": 4,
  },

  "indent_guides": {
    "enabled": false,
  },

  "vertical_scroll_margin": 5,
  "horizontal_scroll_margin": 8,

  "search": {
    "button": false,
  },

  "project_panel": {
    "button": true,
    "hide_gitignore": false,
    "default_width": 260,
    "file_icons": false,
    "folder_icons": false,
    "indent_size": 20,
    "auto_fold_dirs": false,
    "show_diagnostics": "off",
    "sticky_scroll": false,
    "indent_guides": {
      "show": "never",
    },
    "hide_root": true,
  },

  "outline_panel": {
    "button": false,
  },

  "collaboration_panel": {
    "button": false,
  },

  "git_panel": {
    "button": true,
    "default_width": 260,
  },

  "notification_panel": {
    "button": false,
  },

  "agent": {
    "inline_assistant_use_streaming_tools": false,
    "enabled": false,
    "button": false,
  },

  "show_call_status_icon": false,

  // TDOD: Check later.
  "enable_language_server": false,
  "linked_edits": false,

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },

  "tabs": {
    "git_status": true,
    "file_icons": false,
    "show_diagnostics": "off",
  },

  "file_finder": {
    "file_icons": false,
  },

  "extend_comment_on_newline": false,

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "disable_ai": true,

  "auto_update": false,

  "diagnostics": {
    "button": false,
    "include_warnings": false,
  },

  "terminal": {
    "blinking": "on",
  },

  "tasks": {
    "enabled": false,
  },
}
